# Spotify Developer App credentials — pre-configure before shipping the device.
# Register your app at https://developer.spotify.com/dashboard
# Add http://spotifactory.local:8080/callback as an allowed Redirect URI.
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
SPOTIPY_REDIRECT_URI=http://spotifactory.local:8080/callback

# NFC reader port — auto-detected on Pi (USB serial adapter).
# Uncomment and set if auto-detection picks the wrong device.
# NFC_PORT=tty:USB0
