# Spotify Developer App — register at https://developer.spotify.com/dashboard
# Add https://YOUR-WORKER.workers.dev/callback as the Redirect URI.
SPOTIPY_CLIENT_ID=your_client_id_here

# Cloudflare Worker relay URL (no trailing slash).
# Deploy deploy/relay/ first, then paste the worker URL here.
RELAY_URL=https://spotifactory-auth.YOUR-ACCOUNT.workers.dev

# Mac development only — not needed on Pi (PKCE is used instead).
# SPOTIPY_CLIENT_SECRET=your_client_secret_here
# SPOTIPY_REDIRECT_URI=http://127.0.0.1:8080/callback

# NFC reader port — auto-detected on Pi (USB serial adapter).
# Uncomment and set if auto-detection picks the wrong device.
# NFC_PORT=tty:USB0
